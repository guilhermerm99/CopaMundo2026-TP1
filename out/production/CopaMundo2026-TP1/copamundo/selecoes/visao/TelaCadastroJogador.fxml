<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@estilo.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="copamundo.selecoes.visao.TelaCadastroJogadorController">
    <top>
        <VBox spacing="10" style="-fx-background-color: white; -fx-border-color: #BDBDBD; -fx-border-radius: 5;">
            <padding><Insets bottom="15" left="15" right="15" top="15"/></padding>
            <GridPane hgap="10" vgap="10">
                <Label text="Nome:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="campoNome" promptText="Nome completo do jogador" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Posição:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <ComboBox fx:id="comboPosicao" promptText="Selecione" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Número:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="campoNumero" promptText="Ex: 10" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Idade:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="campoIdade" promptText="Idade do jogador" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="Status:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <ComboBox fx:id="comboStatus" promptText="Selecione" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <Label text="Seleção:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <ComboBox fx:id="comboSelecao" promptText="Carregar seleções" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                <columnConstraints>
                    <ColumnConstraints/><ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>
            </GridPane>
            <HBox alignment="CENTER" spacing="10">
                <Button fx:id="btnNovo" onAction="#novo" text="➕  Novo"/>
                <Button fx:id="btnEditar" onAction="#editar" text="✏️  Editar"/>
                <Button fx:id="btnExcluir" onAction="#excluir" text="🗑️  Excluir" styleClass="button-cancelar"/>
                <Button fx:id="btnSalvar" onAction="#salvar" text="💾  Salvar"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="tabelaJogadores">
            <columns>
                <TableColumn fx:id="colunaNome" text="Nome"/>
                <TableColumn fx:id="colunaPosicao" text="Posição"/>
                <TableColumn fx:id="colunaNumero" text="Nº"/>
                <TableColumn fx:id="colunaIdade" text="Idade"/>
                <TableColumn fx:id="colunaStatus" text="Status"/>
                <TableColumn fx:id="colunaSelecao" text="Seleção"/>
            </columns>
        </TableView>
    </center>
</BorderPane>