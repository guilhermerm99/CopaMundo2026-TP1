                                                </HBox>
                                            </children>
                                        </VBox>
                                        <VBox layoutX="10.0" layoutY="10.0" prefHeight="200.0" prefWidth="200.0" spacing="5.0">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="137.0" spacing="5.0">
                                                    <children>
                                                        <Label text="Cpf:">
                                                            <font>
                                                                <Font name="System Bold" size="12.0" />
                                                            </font>
                                                        </Label>
