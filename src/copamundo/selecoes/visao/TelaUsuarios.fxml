                                <TableView prefHeight="303.0" prefWidth="470.0" style="-fx-background-radius: 9;">
                                    <columns>
                                        <TableColumn prefWidth="94.0" text="Nome" />
                                        <TableColumn prefWidth="94.0" text="CPF" />
                                        <TableColumn prefWidth="94.0" text="Função" />
                                        <TableColumn prefWidth="94.0" text="País" />
                                        <TableColumn prefWidth="94.0" text="Status" />
                                    </columns>
                                </TableView>
                                <HBox alignment="CENTER_RIGHT" prefHeight="47.0" prefWidth="473.0" spacing="10.0">
                                    <children>
                                        <Button mnemonicParsing="false" style="-fx-background-radius: 15; -fx-background-color: white;">
                                            <graphic>
                                                <FontIcon iconLiteral="fas-pencil-alt" />
                                            </graphic></Button>
                                        <Button mnemonicParsing="false" style="-fx-background-color: #b22222; -fx-background-radius: 15;" text="Excluir" textFill="WHITE" />
                                    </children></HBox>
