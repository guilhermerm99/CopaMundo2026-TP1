                </VBox>
            </left>
            <center>
                <StackPane fx:id="contentArea" BorderPane.alignment="CENTER">
                    <children>
                        <VBox prefHeight="200.0" prefWidth="100.0" spacing="15.0" style="-fx-background-color: #DCDCDC;">
