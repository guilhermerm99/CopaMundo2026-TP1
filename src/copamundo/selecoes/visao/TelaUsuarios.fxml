                                <HBox prefHeight="37.0" prefWidth="453.0" spacing="25.0">
                                    <children>
                                        <VBox prefHeight="200.0" prefWidth="220.0" spacing="5.0">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="137.0" spacing="5.0">
                                                    <children>
                                                        <Label text="Nome:">
                                                            <font>
                                                                <Font name="System Bold" size="12.0" />
                                                            </font>
                                                        </Label>
                                                        <TextField prefHeight="25.0" prefWidth="145.0" promptText="Nome do usuário" style="-fx-background-radius: 15; -fx-faint-focus-color: transparent; -fx-focus-color: #2E7D32;" />
