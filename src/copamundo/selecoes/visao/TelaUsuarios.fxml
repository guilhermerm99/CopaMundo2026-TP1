                                                </HBox>
                                                <HBox alignment="CENTER_LEFT" layoutX="10.0" layoutY="10.0" prefHeight="25.0" prefWidth="137.0" spacing="5.0">
                                                    <children>
                                                        <Label text="País:">
                                                            <font>
                                                                <Font name="System Bold" size="12.0" />
                                                            </font>
                                                        </Label>
                                                        <TextField promptText="País" style="-fx-background-radius: 15; -fx-faint-focus-color: transparent; -fx-focus-color: #2E7D32;" />
