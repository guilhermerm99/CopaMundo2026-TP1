<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="seu.pacote.MainController">
    <children>
        <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <left>
                <VBox alignment="TOP_CENTER" prefHeight="364.0" prefWidth="127.0" spacing="10.0" style="-fx-background-color: #2E7D32;" BorderPane.alignment="CENTER">
                    <children>
                        <Button fx:id="btnUsuarios" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleMenuUsuarios" prefHeight="25.0" prefWidth="200.0" style="-fx-background-color: #3fa455; -fx-text-fill: white;" text="Usuários">
                            <graphic>
                                <FontIcon iconColor="WHITE" iconLiteral="fas-users" />
                            </graphic>
                        </Button>

                        <Button fx:id="btnRelatorios" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleMenuRelatorios" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Relatórios" textFill="WHITE">
                            <graphic>
                                <FontIcon iconColor="WHITE" iconLiteral="fas-chart-bar" />
                            </graphic>
                        </Button>
                        <Button fx:id="btnRelatorios1" alignment="BASELINE_LEFT" layoutX="16.0" layoutY="65.0" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleMenuRelatorios" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Configurações" textFill="WHITE">
