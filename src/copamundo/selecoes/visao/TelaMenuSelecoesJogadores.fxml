<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15" stylesheets="@estilo.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="copamundo.selecoes.visao.TelaMenuSelecoesJogadoresController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <Label styleClass="label-titulo" text="⚽ Gestão de Seleções e Jogadores"/>

    <Button fx:id="btnSelecoes" mnemonicParsing="false" onAction="#abrirCadastroSelecoes" text="🏆  Seleções"/>
    <Button fx:id="btnJogadores" mnemonicParsing="false" onAction="#abrirCadastroJogadores" text="👤  Jogadores"/>
    <Button fx:id="btnConsulta" mnemonicParsing="false" onAction="#abrirConsulta" text="🔍  Consultas"/>
</VBox>