<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" stylesheets="@estilo.css"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="copamundo.estadios.visao.TelaCadastroEstadiosController">

    <padding>
        <Insets bottom="15" left="15" right="15" top="15"/>
    </padding>

    <Label text="🏟️ Cadastro de Estádios" styleClass="label-titulo"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Nome:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtNome" promptText="Nome do estádio"
                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Cidade:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtCidade" promptText="Cidade"
                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Capacidade:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtCapacidade" promptText="Capacidade"
                   GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER">
        <Button text="➕ Novo"/>
        <Button text="💾 Salvar"/>
        <Button text="✏️ Editar"/>
        <Button text="🗑️ Excluir" styleClass="button-cancelar"/>
    </HBox>

    <TableView fx:id="tabelaEstadios" prefHeight="220">
        <columns>
            <TableColumn text="Nome" prefWidth="180"/>
            <TableColumn text="Cidade" prefWidth="160"/>
            <TableColumn text="Capacidade" prefWidth="120"/>
        </columns>
    </TableView>

</VBox>